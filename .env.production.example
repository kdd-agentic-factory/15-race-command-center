# =============================================================================
# KDD Agentic Factory — RACE Command Center (Production)
# =============================================================================
# Application
APP_ENV=production
APP_NAME=kdd-race-command-center
PORT=8100
LOG_LEVEL=INFO
HOST=0.0.0.0

# Backend port override (if different from PORT)
BACKEND_PORT=${PORT}

# Internal service URLs (Kubernetes DNS)
KDD_PIPELINES_URL=http://06-kdd-data-pipelines.kdd-agentic.svc.cluster.local:8010
COPILOT_URL=http://16-race-ai-copilot.kdd-agentic.svc.cluster.local:8110
DIGITAL_TWIN_URL=http://17-digital-twin-simulation-lab.kdd-agentic.svc.cluster.local:8170
DOCUMENTATION_AGENT_URL=http://05-documentation-agent.kdd-agentic.svc.cluster.local:8004
ORCHESTRATOR_URL=http://01-agent-orchestrator.kdd-agentic.svc.cluster.local:8000
OBSERVABILITY_URL=http://prometheus.kdd-observability.svc.cluster.local:9090

# Feature toggles
ENABLE_MOCK_MODE=false
ENABLE_LIVE_TELEMETRY=true
ENABLE_COPILOT=true
ENABLE_DIGITAL_TWIN=true
ENABLE_PARTS_MODULE=true
ENABLE_PAPER_EVIDENCE_EXPORT=true

# Frontend URL (for CORS, redirects)
FRONTEND_URL=https://race.kdd-agentic.example.com

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.kdd-observability.svc.cluster.local:4317

# CORS — restrict to frontend domain only
CORS_ORIGINS=https://race.kdd-agentic.example.com
